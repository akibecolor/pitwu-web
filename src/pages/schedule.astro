---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="スケジュール | 夢源風人"
  description="夢源風人の活動スケジュール・練習日程です。"
  pageTitle="スケジュール"
  pageSubtitle="Schedule"
>
  <div class="schedule-wrap">
    <div class="schedule-notice">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="notice-icon">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>
        練習場所・時間は天候その他の事情により変更する場合があります。
        見学希望の方は事前に<a href="/contact/">お問合せよりご連絡</a>ください。
      </span>
    </div>

    <div class="calendar-card">
      <div class="calendar-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>活動カレンダー</span>
      </div>
      <div class="calendar-body">
        <iframe
          loading="lazy"
          title="夢源風人 活動カレンダー"
          style="border: 0;"
          src="https://www.google.com/calendar/embed?showTitle=0&showPrint=0&showTz=0&height=600&wkst=2&bgcolor=%23F0F6FF&src=80s4qcc8jd7hisb0k03vkist6g%40group.calendar.google.com&color=%231B3F8B&src=slfifr2ssskd7c6e343jla5i00%40group.calendar.google.com&color=%236EC6F0&ctz=Asia%2FTokyo"
          width="100%"
          height="600"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>
    </div>

    <p class="schedule-footer">
      ご不明な点は<a href="/contact/">お問合せ</a>ください。
    </p>
  </div>
</PageLayout>

<style>
  .schedule-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .schedule-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    background: var(--color-base, #F0F6FF);
    border-left: 4px solid var(--color-sky, #6EC6F0);
    padding: 0.875rem 1.25rem;
    border-radius: 0 6px 6px 0;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(26, 31, 46, 0.75);
  }

  .notice-icon {
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--color-sky, #6EC6F0);
  }

  .schedule-notice a {
    color: var(--color-deep, #1B3F8B);
    text-decoration: underline;
  }

  .calendar-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(27, 63, 139, 0.1);
    overflow: hidden;
    border: 1px solid rgba(27, 63, 139, 0.08);
  }

  .calendar-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.25rem;
    background: var(--color-deep, #1B3F8B);
    color: #ffffff;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .calendar-body iframe {
    display: block;
    width: 100%;
  }

  .schedule-footer {
    font-size: 0.875rem;
    color: rgba(26, 31, 46, 0.55);
    text-align: center;
  }

  .schedule-footer a {
    color: var(--color-deep, #1B3F8B);
    text-decoration: underline;
  }
</style>
