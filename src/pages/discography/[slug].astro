---
// discography/[slug].astro — 作品詳細（長い作品名の折り返し・装飾見出し対応）
import BaseLayout from '../../layouts/BaseLayout.astro';
import pagesData from '../../data/wp-pages.json';
import { wrapLyricsSection } from '../../lib/htmlTransform.js';
import type { GetStaticPaths } from 'astro';
// v2: structured layout for 2019+ songs

export const getStaticPaths: GetStaticPaths = async () => {
  return pagesData.songs.map((song) => ({
    params: { slug: song.slug },
    props: { song },
  }));
};

interface Credits {
  composer?: string | null;
  choreographer?: string | null;
  costumeBy?: string | null;
  narukoBy?: string | null;
  floatBy?: string | null;
  costumeDesignBy?: string | null;
  lyricist?: string | null;
  vocalist?: string | null;
  chorus?: string | null;
  guitarist?: string | null;
  shamisen?: string | null;
  ryukyuAori?: string | null;
}

interface Props {
  song: {
    slug: string;
    title: string;
    content: string;
    year: number | string;
    romaji?: string;
    youtubeId?: string | null;
    youtubeIds?: string[] | null;
    lyrics?: string | null;
    costumeHtml?: string | null;
    yataiHtml?: string | null;
    awardsHtml?: string | null;
    credits?: Credits | null;
  };
}

const { song } = Astro.props;
const yearLabel = typeof song.year === 'string' ? song.year : String(song.year);
const subtitle = song.romaji ? `${yearLabel} — ${song.romaji}` : `${yearLabel} — Works`;

const videoIds = song.youtubeIds?.length ? song.youtubeIds : (song.youtubeId ? [song.youtubeId] : []);
const hasVideos  = videoIds.length > 0;
const primaryVideoId   = videoIds.length >= 2 ? videoIds[0] : null;
const sectionVideoIds  = videoIds.length >= 2 ? videoIds.slice(1) : videoIds;
const hasLyrics  = Boolean(song.lyrics);
const hasCredits = song.credits && Object.values(song.credits).some(Boolean);
// credits オブジェクト自体が存在すれば 2019年以降の構造化ページ
const isStructured = song.credits !== undefined;

const creditLabels: [keyof Credits, string][] = [
  ['choreographer',  '振付'],
  ['costumeDesignBy','衣装デザイン'],
  ['lyricist',       '作詞'],
  ['composer',       '楽曲'],
  ['guitarist',      'ギター'],
  ['shamisen',       '三味線'],
  ['vocalist',       '歌'],
  ['chorus',         'コーラス'],
  ['ryukyuAori',     '琉球煽り'],
  ['costumeBy',      '衣装制作'],
  ['narukoBy',       '鳴子制作'],
  ['floatBy',        '地方車製作'],
];

const legacyContent = wrapLyricsSection(song.content);
---

<BaseLayout
  title={`${song.title} | 作品 | 夢源風人`}
  description={`夢源風人の作品「${song.title}」（${yearLabel}）の紹介。歌詞・クレジット・動画を掲載しています。`}
>
  <div class="song-page">

    <!-- テキストアートヘッダー -->
    <header class="song-header">
      <div class="song-header-bg" aria-hidden="true">
        <span class="ghost-title">{song.title}</span>
      </div>
      <div class="song-header-content">
        <p class="song-year-label">{subtitle}</p>
        <h1 class="song-title">{song.title}</h1>
      </div>
    </header>

    <!-- 本文 -->
    <div class="song-body">
      <div class="song-body-inner">
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <a href="/discography/">作品一覧</a>
          <span aria-hidden="true">›</span>
          <span class="breadcrumb-current">{song.title}</span>
        </nav>

        {primaryVideoId && (
          <div class="primary-video-wrapper">
            <div class="video-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${primaryVideoId}`}
                title={`${song.title} 作品動画`}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            </div>
          </div>
        )}

        {isStructured ? (
          <div class="structured-sections">

            <section class="section section--lyrics">
              <h2 class="section-title">
                <span class="section-title-en">Lyrics</span>
                <span class="section-title-ja">歌詞</span>
              </h2>
              {hasLyrics ? (
                <div class="lyrics-card">
                  <div class="lyrics-text" set:html={song.lyrics} />
                </div>
              ) : (
                <div class="coming-soon">
                  <span class="coming-soon-label">Coming Soon</span>
                  <p class="coming-soon-note">歌詞を準備中です</p>
                </div>
              )}
            </section>

            <section class="section section--costume">
              <h2 class="section-title">
                <span class="section-title-en">Costume</span>
                <span class="section-title-ja">衣装</span>
              </h2>
              {song.costumeHtml ? (
                <div class="photo-content wp-content" set:html={song.costumeHtml} />
              ) : (
                <div class="coming-soon">
                  <span class="coming-soon-label">Coming Soon</span>
                  <p class="coming-soon-note">衣装写真を準備中です</p>
                </div>
              )}
            </section>

            <section class="section section--float">
              <h2 class="section-title">
                <span class="section-title-en">Yatai</span>
                <span class="section-title-ja">地方車</span>
              </h2>
              {song.yataiHtml ? (
                <div class="photo-content wp-content" set:html={song.yataiHtml} />
              ) : (
                <div class="coming-soon">
                  <span class="coming-soon-label">Coming Soon</span>
                  <p class="coming-soon-note">地方車写真を準備中です</p>
                </div>
              )}
            </section>

            <section class="section section--credits">
              <h2 class="section-title">
                <span class="section-title-en">Credits</span>
                <span class="section-title-ja">作品情報</span>
              </h2>
              {hasCredits ? (
                <dl class="credits-list">
                  {creditLabels.map(([key, label]) =>
                    song.credits?.[key] ? (
                      <div class="credits-row">
                        <dt class="credits-label">{label}</dt>
                        <dd class="credits-value">{song.credits?.[key]}</dd>
                      </div>
                    ) : null
                  )}
                </dl>
              ) : (
                <div class="coming-soon">
                  <span class="coming-soon-label">Coming Soon</span>
                  <p class="coming-soon-note">クレジット情報を準備中です</p>
                </div>
              )}
            </section>

            {song.awardsHtml && (
              <section class="section section--awards">
                <h2 class="section-title">
                  <span class="section-title-en">Awards</span>
                  <span class="section-title-ja">受賞歴</span>
                </h2>
                <div class="awards-content wp-content" set:html={song.awardsHtml} />
              </section>
            )}

            <section class="section section--video">
              <h2 class="section-title">
                <span class="section-title-en">Video</span>
                <span class="section-title-ja">作品動画</span>
              </h2>
              {hasVideos ? (
                <div class="video-list">
                  {sectionVideoIds.map((id) => (
                    <div class="video-wrapper">
                      <iframe
                        src={`https://www.youtube.com/embed/${id}`}
                        title={`${song.title} 作品動画`}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="coming-soon">
                  <span class="coming-soon-label">Coming Soon</span>
                  <p class="coming-soon-note">動画を準備中です</p>
                </div>
              )}
            </section>

          </div>
        ) : (
          <div class="song-content wp-content" set:html={legacyContent} />
        )}

        <div class="back-link">
          <a href="/discography/">← 作品一覧に戻る</a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .song-page {
    padding-top: 64px; /* header height */
  }

  /* ── テキストアートヘッダー ── */
  .song-header {
    position: relative;
    background: linear-gradient(135deg, var(--color-deep, #1B3F8B) 0%, #1a3580 60%, #0f2460 100%);
    padding: 4rem 1.5rem 3.5rem;
    text-align: center;
    overflow: hidden;
  }

  /* ゴーストテキスト（背景装飾）— 中央に収めず XY ずらし＋大きめでクリップし、装飾感を出す */
  .song-header-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
  }

  /* 長いタイトルは折り返し。nowrap だと装飾テキストが横に無限に伸びる */
  .ghost-title {
    font-family: 'Noto Serif JP', serif;
    box-sizing: border-box;
    width: 100%;
    max-width: min(96vw, 52rem);
    margin: 0 auto;
    padding: 0 clamp(0.5rem, 3vw, 1.5rem);
    font-size: clamp(2.5rem, 11vw, 10rem);
    font-weight: 900;
    color: #ffffff;
    opacity: 0.05;
    white-space: normal;
    line-height: 1.02;
    letter-spacing: 0.03em;
    user-select: none;
    text-align: center;
    overflow-wrap: anywhere;
    word-break: keep-all;
    transform: translate(4%, -10%) rotate(-2deg);
    transform-origin: 50% 40%;
  }

  /* 前面コンテンツ */
  .song-header-content {
    position: relative;
    z-index: 1;
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .song-year-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.35em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }

  .song-title {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    line-height: 1.35;
    max-width: 100%;
    margin-inline: auto;
    padding: 0 0.25rem;
    overflow-wrap: anywhere;
    word-break: keep-all;
    text-wrap: balance;
  }

  /* ── 本文 ── */
  .song-body {
    padding: 4rem 1.5rem 6rem;
  }

  .song-body-inner {
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    font-size: 0.875rem;
    color: rgba(26, 31, 46, 0.55);
    margin-bottom: 2rem;
  }

  .breadcrumb-current {
    min-width: 0;
    flex: 1 1 12rem;
    color: var(--color-ink, #1a1f2e);
    overflow-wrap: anywhere;
    word-break: keep-all;
    line-height: 1.5;
  }

  .breadcrumb a {
    color: var(--color-deep, #1B3F8B);
    text-decoration: none;
  }

  .breadcrumb a:hover { text-decoration: underline; }

  /* ── 構造化セクション ── */
  .structured-sections {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .section {
    border-top: 2px solid rgba(27, 63, 139, 0.12);
    padding-top: 2.5rem;
  }

  .section-title {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 1.75rem;
  }

  .section-title-en {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
  }

  .section-title-ja {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    letter-spacing: 0.08em;
  }

  /* 衣装・地方車写真 */
  .photo-content :global(img) {
    margin-bottom: 1rem;
    border-radius: 8px;
  }

  .photo-content :global(img:last-child) {
    margin-bottom: 0;
  }

  /* Coming Soon カード */
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2.5rem 2rem;
    border: 2px dashed rgba(27, 63, 139, 0.18);
    border-radius: 10px;
    background: rgba(27, 63, 139, 0.025);
    max-width: 480px;
    text-align: center;
  }

  .coming-soon-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
  }

  .coming-soon-note {
    font-size: 0.8125rem;
    color: rgba(26, 31, 46, 0.4);
    letter-spacing: 0.05em;
  }

  /* メイン動画（見出しなし・セクション上） */
  .primary-video-wrapper {
    margin-bottom: 2.5rem;
  }

  /* 受賞歴コンテンツ */
  .awards-content :global(ul),
  .awards-content :global(ol) {
    padding-left: 1.25rem;
    line-height: 1.9;
    margin: 0;
  }

  .awards-content :global(li) {
    font-size: 0.9375rem;
    color: rgba(26, 31, 46, 0.82);
    margin-bottom: 0.3em;
  }

  .awards-content :global(p) {
    font-size: 0.9375rem;
    line-height: 1.9;
    color: rgba(26, 31, 46, 0.82);
    margin: 0 0 0.5em;
  }

  /* 作品動画 */
  .video-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: 720px;
    padding-bottom: min(56.25%, 405px);
    height: 0;
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 4px 24px rgba(27, 63, 139, 0.18);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }

  /*
   * 歌詞カード（募集・演舞依頼の section-card と同一トーン）
   * structured（microCMS）と WordPress 移行（.wp-lyrics）の両方に適用
   */
  .lyrics-card,
  .wp-content :global(.wp-lyrics) {
    --card-r: 12px;
    position: relative;
    padding: 1.65rem 1.5rem 1.75rem;
    border-radius: var(--card-r);
    background: linear-gradient(165deg, rgba(240, 246, 255, 0.55), rgba(255, 255, 255, 0.98));
    border: 1px solid rgba(110, 198, 240, 0.2);
    box-shadow:
      0 8px 22px rgba(27, 63, 139, 0.07),
      0 2px 8px rgba(26, 31, 46, 0.04);
    overflow: hidden;
    max-width: 42rem;
    font-family: 'Noto Serif JP', serif;
    font-size: 0.9375rem;
    line-height: 2;
    color: rgba(26, 31, 46, 0.88);
    overflow-wrap: break-word;
    word-break: keep-all;
  }

  .wp-content :global(.wp-lyrics) {
    margin: 0 0 2.5rem;
  }

  .lyrics-card::before,
  .wp-content :global(.wp-lyrics)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: var(--card-r) 0 0 var(--card-r);
    background: linear-gradient(
      180deg,
      rgba(212, 168, 75, 0.55),
      rgba(110, 198, 240, 0.75)
    );
  }

  .lyrics-card .lyrics-text {
    position: relative;
    z-index: 1;
  }

  .wp-content :global(.wp-lyrics > *) {
    position: relative;
    z-index: 1;
  }

  /* 歌詞本文（2019年以降の structured / microCMS） */
  .lyrics-text {
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    line-height: 2;
    color: rgba(26, 31, 46, 0.88);
    max-width: none;
    overflow-wrap: break-word;
    word-break: keep-all;
  }

  .lyrics-text :global(p) {
    margin: 0 0 0.65em;
    line-height: 2;
  }

  .lyrics-text :global(p:last-child) {
    margin-bottom: 0;
  }

  /* クレジット */
  .credits-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.875rem 1.5rem;
    max-width: 480px;
  }

  .credits-row {
    display: contents;
  }

  .credits-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
    white-space: nowrap;
    padding-top: 0.1em;
  }

  .credits-value {
    font-family: 'Noto Serif JP', serif;
    font-size: 0.9375rem;
    color: var(--color-ink, #1A1F2E);
    line-height: 1.6;
  }

  /* ── WordPress コンテンツ (旧形式) ── */
  .wp-content {
    --wp-block-gap: 1.25rem;
    --wp-heading-gap: 1.5rem;
  }

  .wp-content :global(img.banner),
  .wp-content :global(img[class*="banner"]) {
    display: none;
  }

  .wp-content :global(h2),
  .wp-content :global(h3) {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin: var(--wp-heading-gap) 0 0.65rem;
  }

  .wp-content :global(h2:first-child),
  .wp-content :global(h3:first-child) {
    margin-top: 0;
  }

  /* 動画ブロック直後の見出しは上余白を詰める（二重マージン防止） */
  .wp-content :global(.youtube + h2),
  .wp-content :global(.youtube + h3),
  .wp-content :global(.embed-youtube + h2),
  .wp-content :global(.embed-youtube + h3) {
    margin-top: 1rem;
  }

  /* 画像・段落の直後の見出し */
  .wp-content :global(p + h2),
  .wp-content :global(p + h3),
  .wp-content :global(a:has(> img) + h2),
  .wp-content :global(a:has(> img) + h3),
  .wp-content :global(figure + h2),
  .wp-content :global(figure + h3) {
    margin-top: 1rem;
  }

  .wp-content :global(h2) { font-size: 1.375rem; }
  .wp-content :global(h3) { font-size: 1.125rem; }

  .wp-content :global(p) {
    line-height: 2;
    margin: 0 0 var(--wp-block-gap);
    color: var(--color-ink, #1A1F2E);
  }

  /* WordPress 移行: 歌詞ブロック（上記 .lyrics-card と共通のカード装飾） */
  .wp-content :global(.wp-lyrics > div:empty) {
    display: none;
  }

  .wp-content :global(.wp-lyrics h3) {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-deep, #1b3f8b);
    margin: 0 0 0.9rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid rgba(27, 63, 139, 0.12);
    letter-spacing: 0.04em;
  }

  .wp-content :global(.wp-lyrics p) {
    margin-bottom: 0.5em;
    line-height: 2;
    min-height: 0;
  }

  .wp-content :global(.wp-lyrics p:last-child) {
    margin-bottom: 0;
  }

  .wp-content :global(.wp-lyrics .home-text) {
    white-space: normal;
    margin: 0;
    line-height: 2;
  }

  .wp-content :global(.wp-lyrics .home-text p) {
    margin-bottom: 0.5em;
  }

  .wp-content :global(.wp-lyrics .home-text p:last-child) {
    margin-bottom: 0;
  }

  .wp-content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }

  /* 画像だけの段落：行ボックスの余分な下隙間を抑える */
  .wp-content :global(p:has(> img:only-child)),
  .wp-content :global(p:has(> a:only-child > img)) {
    line-height: 0;
    margin-bottom: var(--wp-block-gap);
  }

  .wp-content :global(p:has(> img:only-child) img),
  .wp-content :global(p:has(> a:only-child > img) img) {
    margin: 0;
  }

  .wp-content :global(p > a:only-child:has(> img)) {
    display: block;
    width: fit-content;
    max-width: 100%;
  }

  /* p 外の画像リンク（先頭バナー・見出し直後の単体 a など）。p 内は段落 margin のみ */
  .wp-content :global(a:has(> img):not(p *)) {
    display: block;
    width: fit-content;
    max-width: 100%;
    margin: 0 0 var(--wp-block-gap);
  }

  .wp-content :global(p a:has(> img)) {
    margin-bottom: 0;
  }

  .wp-content :global(figure) {
    margin: 0 0 var(--wp-block-gap);
    padding: 0;
  }

  .wp-content :global(figure img) {
    width: 100%;
  }

  .wp-content :global(ul.home-list) {
    margin: 0 0 var(--wp-block-gap);
    padding-left: 1.25rem;
    line-height: 1.75;
  }

  .wp-content :global(iframe) {
    max-width: 100%;
    border-radius: 8px;
  }

  .wp-content :global(.youtube),
  .wp-content :global(.embed-youtube) {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    margin: 0 0 1.5rem;
  }

  .wp-content :global(.youtube iframe),
  .wp-content :global(.embed-youtube iframe) {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .wp-content :global(.home-text) {
    line-height: 2;
    white-space: normal;
    margin: 0 0 var(--wp-block-gap);
  }

  .back-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(27, 63, 139, 0.1);
  }

  .back-link a {
    font-size: 0.9375rem;
    color: var(--color-deep, #1B3F8B);
