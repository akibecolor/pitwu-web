---
// discography/index.astro — 作品一覧（長い作品名でも折り返し・カード崩れを防ぐ）
import PageLayout from '../../layouts/PageLayout.astro';
import pagesData from '../../data/wp-pages.json';

const songs = pagesData.songs;
---

<PageLayout
  title="作品 | 夢源風人"
  description="大阪・東海を拠点に活動する夢源風人の作品一覧。年度ごとの楽曲・紹介・歌詞への導線です。"
  pageTitle="作品"
  pageSubtitle="Works"
>
  <ul class="song-list">
    {songs.map((song) => (
      <li class="song-item">
        <a href={`/discography/${song.slug}/`} class="song-link">
          <div class="song-link-top">
            <span class="song-year">{song.year}</span>
            <span class="song-arrow" aria-hidden="true">→</span>
          </div>
          <span class="song-name">{song.title}</span>
        </a>
      </li>
    ))}
  </ul>
</PageLayout>

<style>
  .song-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 1.25rem;
  }

  .song-item {
    --song-card-r: 12px;
    min-width: 0;
    border-radius: var(--song-card-r);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow:
      0 8px 24px rgba(27, 63, 139, 0.08),
      0 2px 8px rgba(26, 31, 46, 0.04);
  }

  .song-item:hover {
    transform: translateY(-3px);
    box-shadow:
      0 14px 36px rgba(27, 63, 139, 0.12),
      0 4px 12px rgba(26, 31, 46, 0.06);
  }

  .song-link {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-height: 100%;
    min-width: 0;
    padding: 1.2rem 1.35rem 1.35rem;
    text-decoration: none;
    color: var(--color-ink, #1A1F2E);
    background: linear-gradient(155deg, rgba(240, 246, 255, 0.95), rgba(255, 255, 255, 0.98));
    border: 1px solid rgba(110, 198, 240, 0.22);
    border-left: 4px solid var(--color-sky, #6ec6f0);
    transition: border-left-color 0.2s ease, background 0.2s ease;
  }

  .song-item:hover .song-link {
    border-left-color: var(--color-deep, #1b3f8b);
    background: linear-gradient(155deg, rgba(255, 255, 255, 0.98), rgba(240, 246, 255, 0.88));
  }

  .song-link-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .song-year {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-sky, #6ec6f0);
    white-space: nowrap;
  }

  .song-name {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.55;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: normal;
    line-break: strict;
  }

  .song-arrow {
    color: rgba(110, 198, 240, 0.85);
    font-size: 1.25rem;
    line-height: 1;
    transition: color 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .song-item:hover .song-arrow {
    color: var(--color-deep, #1b3f8b);
    transform: translateX(5px);
  }
</style>
