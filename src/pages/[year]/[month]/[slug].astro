---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getAllArticlesWithContent } from '../../../lib/microcms.js';
import { getSourceDate } from '../../../lib/articleHelpers.js';
import type { GetStaticPaths } from 'astro';
import type { Article } from '../../../types/index.js';

export const getStaticPaths: GetStaticPaths = async () => {
  // content を含む全記事を一括取得（12回のバッチ API で完了）
  // 旧方式: 一覧取得 + 1127件の個別取得 = 1139回 → 新方式: 12回
  const articles = await getAllArticlesWithContent();

  return articles.map((article) => {
    const date = new Date(getSourceDate(article));
    const year = String(date.getFullYear());
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const slug = decodeURIComponent(article.slug);
    return {
      params: { year, month, slug },
      props: { article },
    };
  });
};

interface Props {
  article: Article;
}

const { article } = Astro.props;
---

<ArticleLayout article={article} comments={[]} />
