---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getAllArticles } from '../lib/microcms.js';
import { Image } from 'astro:assets';
import topimage from '../assets/topimage.jpg';

const allArticles = await getAllArticles();
const latestArticles = allArticles.slice(0, 6);
---

<BaseLayout
  title="夢源風人 — 人と自然は風でつながる"
  description="よさこいチーム「夢源風人」の公式ウェブサイト。活動報告・メンバー情報をお届けします。"
>
  <!-- ヒーローセクション -->
  <section class="hero" aria-label="ヒーロー">
    <div class="hero-image-wrap">
      <Image
        src={topimage}
        alt="夢源風人 舞踊の様子"
        width={1920}
        height={1080}
        loading="eager"
        class="hero-image"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
      <!-- 流線装飾 -->
      <div class="hero-lines" aria-hidden="true">
        <svg class="lines-svg" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <path d="M-100 400 Q300 200 700 350 Q1000 480 1400 250" stroke="rgba(110,198,240,0.15)" stroke-width="2" fill="none"/>
          <path d="M-100 500 Q400 300 800 420 Q1100 520 1400 350" stroke="rgba(110,198,240,0.1)" stroke-width="1.5" fill="none"/>
          <path d="M-100 300 Q200 150 600 280 Q900 390 1400 180" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none"/>
        </svg>
      </div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title">夢源風人</h1>
      <p class="hero-catchcopy">
        人と自然は風でつながる<br />
        人と人は思いでつながる
      </p>
      <a href="/articles/" class="hero-cta">記事一覧を見る</a>
    </div>
  </section>

  <!-- チームについてセクション -->
  <section class="about-section" aria-labelledby="about-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="about-heading">
        <span class="section-heading-en">About</span>
        チームについて
      </h2>

      <div class="about-grid">
        <div class="about-card about-card--main">
          <h3 class="about-card-title">生い立ち</h3>
          <p>
            夢源風人（むげんかじぴとぅ）は、高知の「よさこい祭り」と大阪の「こいや祭り」に
            参加しようと集まってできた「よさこいチーム」です。<br />
            2001年10月1日に結成、大阪市を拠点とし、お祭りに参加することを目的として活動しています。
          </p>
        </div>

        <div class="about-card">
          <h3 class="about-card-title">チームコンセプト</h3>
          <p class="concept-quote">『目には見えない思いのつながり』</p>
          <p class="concept-ref">〜2001年チーム結成の代表の言葉〜</p>
          <p>
            人それぞれ夢を持ち、夢への希望・勇気を感じ、力が湧きでてくる。
            共に高めあい、助けあって生きていく。それは自然との間でも同じこと。<br />
            人と人は思いでつながる。自然と人は風でつながる。
          </p>
        </div>

        <div class="about-card">
          <h3 class="about-card-title">チーム名の由来</h3>
          <dl class="name-list">
            <dt>夢源 <span class="reading">-むげん-</span></dt>
            <dd>お祭りやチームを通した出逢いや経験が、夢の源（夢のきっかけ・夢へ向かうエネルギー）となるように。</dd>
            <dt>風人 <span class="reading">-かじぴとぅ-</span></dt>
            <dd>思いをもつ人。自然と共に生きる人。<br /><small>※沖縄・西表島方言の「風（かじ）」と「人（ぴとぅ）」をくっつけた言葉。</small></dd>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- スケジュールセクション -->
  <section class="schedule-section" aria-labelledby="schedule-heading">
    <div class="section-inner">
      <h2 class="section-heading section-heading--light" id="schedule-heading">
        <span class="section-heading-en">Schedule</span>
        直近のイベント
      </h2>

      <div class="calendar-card">
        <iframe
          loading="lazy"
          title="夢源風人 活動カレンダー"
          style="border: 0;"
          src="https://www.google.com/calendar/embed?showTitle=0&showPrint=0&showTz=0&height=400&wkst=2&bgcolor=%231B3F8B&src=80s4qcc8jd7hisb0k03vkist6g%40group.calendar.google.com&color=%236EC6F0&ctz=Asia%2FTokyo&mode=AGENDA"
          width="100%"
          height="400"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>

      <div class="section-more">
        <a href="/schedule/" class="more-link more-link--light">スケジュール詳細を見る →</a>
      </div>
    </div>
  </section>

  <!-- 練習会セクション -->
  <section class="practice-section" aria-labelledby="practice-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="practice-heading">
        <span class="section-heading-en">Practice</span>
        練習会について
      </h2>

      <div class="practice-grid">
        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3>開催日</h3>
          <p>金曜・土曜・日曜を中心に開催しています。<br />詳細はスケジュールページをご確認ください。</p>
        </div>

        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3>活動エリア</h3>
          <p>大阪・東海を中心に活動しています。<br />各地にメンバーがおり、それぞれの事情に合わせた参加ができます。</p>
        </div>

        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>見学歓迎</h3>
          <p>未経験者・初心者大歓迎です。<br />見学希望の方は事前に<a href="/contact/">お問合せ</a>ください。</p>
        </div>
      </div>

      <div class="section-more">
        <a href="/recruit/" class="more-link">メンバー募集ページへ →</a>
      </div>
    </div>
  </section>

  <!-- 最新記事セクション -->
  <section class="latest-section" aria-labelledby="latest-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="latest-heading">
        <span class="section-heading-en">Latest</span>
        最新の記事
      </h2>

      {latestArticles.length > 0 ? (
        <div class="articles-grid">
          {latestArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      ) : (
        <p class="no-articles">記事はまだありません。</p>
      )}

      <div class="section-more">
        <a href="/articles/" class="more-link">すべての記事を見る →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ヒーロー */
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(27, 63, 139, 0.72) 0%,
      rgba(27, 63, 139, 0.45) 50%,
      rgba(110, 198, 240, 0.2) 100%
    );
  }

  .hero-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .lines-svg {
    width: 100%;
    height: 100%;
    animation: drift 12s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: translateX(-2%) translateY(0); }
    to   { transform: translateX(2%) translateY(-1%); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #ffffff;
    padding: 0 1.5rem;
    animation: fadeInUp 1s ease 0.2s both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
  }

  .hero-catchcopy {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(0.9rem, 2.5vw, 1.25rem);
    font-weight: 400;
    line-height: 2;
    letter-spacing: 0.1em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    margin-bottom: 2.5rem;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-cta {
    display: inline-block;
    padding: 0.875rem 2.25rem;
    background-color: var(--color-sky, #6EC6F0);
    color: var(--color-deep, #1B3F8B);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 16px rgba(110, 198, 240, 0.4);
  }

  .hero-cta:hover {
    background-color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(110, 198, 240, 0.5);
  }

  /* 最新記事セクション */
  .latest-section {
    padding: 5rem 0;
  }

  .section-inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-heading {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .section-heading-en {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .no-articles {
    text-align: center;
    color: rgba(26, 31, 46, 0.5);
    padding: 3rem 0;
  }

  .section-more {
    margin-top: 3rem;
    text-align: center;
  }

  .more-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-deep, #1B3F8B);
    text-decoration: none;
    border-bottom: 2px solid var(--color-gold, #D4A84B);
    padding-bottom: 0.25rem;
    transition: color 0.2s ease;
    letter-spacing: 0.05em;
  }

  .more-link:hover {
    color: var(--color-sky, #6EC6F0);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  /* チームについて */
  .about-section {
    padding: 5rem 0;
    background: #ffffff;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .about-card--main {
    grid-column: 1 / -1;
  }

  .about-card {
    background: var(--color-base, #F0F6FF);
    border-radius: 10px;
    padding: 1.75rem 2rem;
    border-left: 4px solid var(--color-sky, #6EC6F0);
  }

  .about-card-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 0.875rem;
    letter-spacing: 0.05em;
  }

  .about-card p {
    font-size: 0.9375rem;
    line-height: 2;
    color: var(--color-ink, #1A1F2E);
  }

  .concept-quote {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.125rem !important;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B) !important;
    margin-bottom: 0.25rem !important;
  }

  .concept-ref {
    font-size: 0.8125rem !important;
    color: rgba(26, 31, 46, 0.5) !important;
    margin-bottom: 0.75rem !important;
  }

  .name-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .name-list dt {
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
  }

  .name-list .reading {
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(26, 31, 46, 0.6);
    margin-left: 0.25rem;
  }

  .name-list dd {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--color-ink, #1A1F2E);
    padding-left: 1rem;
  }

  .name-list small {
    font-size: 0.8125rem;
    color: rgba(26, 31, 46, 0.55);
  }

  /* スケジュール */
  .schedule-section {
    padding: 5rem 0;
    background: var(--color-deep, #1B3F8B);
  }

  .section-heading--light .section-heading-en {
    color: var(--color-sky, #6EC6F0);
  }

  .section-heading--light {
    color: #ffffff;
  }

  .calendar-card {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .calendar-card iframe {
    display: block;
    width: 100%;
  }

  .more-link--light {
    color: rgba(255, 255, 255, 0.85) !important;
    border-color: var(--color-gold, #D4A84B) !important;
  }

  .more-link--light:hover {
    color: #ffffff !important;
  }

  /* 練習会 */
  .practice-section {
    padding: 5rem 0;
    background: #ffffff;
  }

  .practice-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .practice-card {
    background: var(--color-base, #F0F6FF);
    border-radius: 10px;
    padding: 1.75rem 1.5rem;
    text-align: center;
  }

  .practice-icon {
    width: 56px;
    height: 56px;
    background: var(--color-deep, #1B3F8B);
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .practice-card h3 {
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 0.625rem;
  }

  .practice-card p {
    font-size: 0.875rem;
    line-height: 1.8;
    color: rgba(26, 31, 46, 0.75);
  }

  .practice-card a {
    color: var(--color-deep, #1B3F8B);
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-card--main {
      grid-column: 1;
    }

    .practice-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
