---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getAllArticles } from '../lib/microcms.js';
import { Image } from 'astro:assets';
import topimage from '../assets/topimage.jpg';

const allArticles = await getAllArticles();
const latestArticles = allArticles.slice(0, 6);
---

<BaseLayout
  title="夢源風人 | よさこいチーム（大阪・東海）"
  description="目には見えない思いのつながり。大阪・東海を拠点に活動するよさこいチーム「夢源風人（むげんかじぴとぅ）」の公式サイト。活動報告・作品・スケジュールなどをお届けします。"
>
  <!-- ヒーローセクション -->
  <section class="hero" aria-label="ヒーロー">
    <div class="hero-image-wrap">
      <Image
        src={topimage}
        alt="夢源風人 舞踊の様子"
        width={1920}
        height={1080}
        loading="eager"
        fetchpriority="high"
        class="hero-image"
      />
      <div class="hero-overlay" aria-hidden="true"></div>
      <!-- 流線装飾 -->
      <div class="hero-lines" aria-hidden="true">
        <svg class="lines-svg" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <path d="M-100 400 Q300 200 700 350 Q1000 480 1400 250" stroke="rgba(110,198,240,0.15)" stroke-width="2" fill="none"/>
          <path d="M-100 500 Q400 300 800 420 Q1100 520 1400 350" stroke="rgba(110,198,240,0.1)" stroke-width="1.5" fill="none"/>
          <path d="M-100 300 Q200 150 600 280 Q900 390 1400 180" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none"/>
        </svg>
      </div>
    </div>

    <div class="hero-content">
      <h1 class="hero-title">目には見えない思いのつながり</h1>
      <p class="hero-catchcopy">
        人と自然は風でつながり、<br />
        人と人は思いでつながる
      </p>
      <nav class="hero-cta-group" aria-label="主要メニュー">
        <a href="/discography/" class="hero-cta">
          <span class="hero-cta-en">Works</span>
          <span class="hero-cta-ja">作品</span>
          <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/enbu-irai/" class="hero-cta">
          <span class="hero-cta-en">Booking</span>
          <span class="hero-cta-ja">演舞依頼</span>
          <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/articles/" class="hero-cta">
          <span class="hero-cta-en">Blog</span>
          <span class="hero-cta-ja">ブログ</span>
          <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
      </nav>
    </div>
  </section>

  <!-- 夢源風人についてセクション -->
  <section class="about-section" aria-labelledby="about-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="about-heading">
        <span class="section-heading-en">About</span>
        夢源風人について
      </h2>

      <div class="about-grid">
        <div class="about-card about-card--main">
          <h3 class="about-card-title">生い立ち</h3>
          <p>
            夢源風人（むげんかじぴとぅ）は、高知の「よさこい祭り」と大阪の「こいや祭り」に
            参加しようと集まってできた「よさこいチーム」です。<br />
            2001年10月1日に結成、大阪市を拠点とし、お祭りに参加することを目的として活動しています。
          </p>
        </div>

        <div class="about-card">
          <h3 class="about-card-title">チームコンセプト</h3>
          <p class="concept-quote">『目には見えない思いのつながり』</p>
          <p class="concept-ref">〜2001年チーム結成の代表の言葉〜</p>
          <p>
            人それぞれ夢を持ち、夢への希望・勇気を感じ、力が湧きでてくる。
            共に高めあい、助けあって生きていく。それは自然との間でも同じこと。<br />
            人と人は思いでつながる。自然と人は風でつながる。
          </p>
        </div>

        <div class="about-card">
          <h3 class="about-card-title">チーム名の由来</h3>
          <dl class="name-list">
            <dt>夢源 <span class="reading">-むげん-</span></dt>
            <dd>お祭りやチームを通した出逢いや経験が、夢の源（夢のきっかけ・夢へ向かうエネルギー）となるように。</dd>
            <dt>風人 <span class="reading">-かじぴとぅ-</span></dt>
            <dd>思いをもつ人。自然と共に生きる人。<br /><small>※沖縄・西表島方言の「風（かじ）」と「人（ぴとぅ）」をくっつけた言葉。</small></dd>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- 作品動画セクション -->
  <section class="videos-section" aria-labelledby="videos-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="videos-heading">
        <span class="section-heading-en">Movie</span>
        作品動画
      </h2>
      <div class="videos-grid">
        <figure class="video-item">
          <div class="video-wrap">
            <iframe
              src="https://www.youtube.com/embed/8z6wLbbbPq0"
              title="群青ひゅるり｜春風のおまつり 作品動画"
              frameborder="0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <figcaption class="video-caption">群青ひゅるり｜春風のおまつり</figcaption>
        </figure>
        <figure class="video-item">
          <div class="video-wrap">
            <iframe
              src="https://www.youtube.com/embed/nj0q9wjunRM"
              title="群青ひゅるり｜京都さくらよさこい 作品動画"
              frameborder="0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <figcaption class="video-caption">群青ひゅるり｜京都さくらよさこい</figcaption>
        </figure>
        <figure class="video-item">
          <div class="video-wrap">
            <iframe
              src="https://www.youtube.com/embed/DwwVPj2z_e0"
              title="TATTOBU!!!!!｜よさこい祭り 作品動画"
              frameborder="0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <figcaption class="video-caption">TATTOBU!!!!!｜よさこい祭り</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- スケジュールセクション -->
  <section class="schedule-section" aria-labelledby="schedule-heading">
    <div class="section-inner">
      <h2 class="section-heading section-heading--light" id="schedule-heading">
        <span class="section-heading-en">Schedule</span>
        直近のイベント
      </h2>

      <div class="calendar-card">
        <iframe
          loading="lazy"
          title="夢源風人 活動カレンダー"
          style="border: 0;"
          src="https://www.google.com/calendar/embed?showTitle=0&showPrint=0&showTz=0&height=400&wkst=2&bgcolor=%231B3F8B&src=80s4qcc8jd7hisb0k03vkist6g%40group.calendar.google.com&color=%236EC6F0&ctz=Asia%2FTokyo&mode=AGENDA"
          width="100%"
          height="400"
          frameborder="0"
          scrolling="no"
        ></iframe>
      </div>

      <div class="section-more">
        <a href="/schedule/" class="more-link more-link--light">スケジュール詳細を見る →</a>
      </div>
    </div>
  </section>

  <!-- 練習会セクション -->
  <section class="practice-section" aria-labelledby="practice-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="practice-heading">
        <span class="section-heading-en">Practice</span>
        練習会について
      </h2>

      <div class="practice-grid">
        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3>開催日</h3>
          <p>金曜・土曜・日曜を中心に開催しています。詳細はスケジュールページをご確認ください。</p>
        </div>

        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3>活動エリア</h3>
          <p>大阪・東海を中心に活動しています。<br />各地にメンバーがおり、それぞれの事情に合わせた参加ができます。</p>
        </div>

        <div class="practice-card">
          <div class="practice-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>見学歓迎</h3>
          <p>未経験者・初心者大歓迎です。<br />見学希望の方は事前に<a href="/contact/">お問合せ</a>ください。</p>
        </div>
      </div>

      <div class="section-more">
        <a href="/recruit/" class="more-link">メンバー募集ページへ →</a>
      </div>
    </div>
  </section>

  <!-- 最新記事セクション -->
  <section class="latest-section" aria-labelledby="latest-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="latest-heading">
        <span class="section-heading-en">Latest</span>
        最新の記事
      </h2>

      {latestArticles.length > 0 ? (
        <div class="articles-grid">
          {latestArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      ) : (
        <p class="no-articles">記事はまだありません。</p>
      )}

      <div class="section-more">
        <a href="/articles/" class="more-link">すべての記事を見る →</a>
      </div>
    </div>
  </section>

  <!-- 協賛セクション -->
  <section class="sponsors-section" aria-labelledby="sponsors-heading">
    <div class="section-inner">
      <h2 class="section-heading" id="sponsors-heading">
        <span class="section-heading-en">Sponsors</span>
        協賛
      </h2>
      <ul class="sponsors-list">
        <li class="sponsor-item">
          <img src="/sponsors/chiyocon_logo.png" alt="株式会社 千代田コンサルタント" loading="lazy" />
        </li>
        <li class="sponsor-item">
          <img src="/sponsors/chacott_logo_pinkback.png" alt="Chacott" loading="lazy" />
        </li>
        <li class="sponsor-item">
          <img src="/sponsors/tis-license-logo.png" alt="T.I.S Corporation" loading="lazy" />
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* ヒーロー */
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(27, 63, 139, 0.72) 0%,
      rgba(27, 63, 139, 0.45) 50%,
      rgba(110, 198, 240, 0.2) 100%
    );
  }

  .hero-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .lines-svg {
    width: 100%;
    height: 100%;
    animation: drift 12s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: translateX(-2%) translateY(0); }
    to   { transform: translateX(2%) translateY(-1%); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #ffffff;
    padding: 0 1.5rem;
    animation: fadeInUp 1s ease 0.2s both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 1行固定。幅に合わせて文字サイズが収まるよう調整 */
  .hero-title {
    font-family: 'Noto Serif JP', serif;
    white-space: nowrap;
    font-size: clamp(0.9375rem, calc((100vw - 3rem) / 15.5), 2.125rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
    margin-left: auto;
    margin-right: auto;
    max-width: calc(100vw - 3rem);
  }

  .hero-catchcopy {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(0.9rem, 2.5vw, 1.25rem);
    font-weight: 400;
    line-height: 2;
    letter-spacing: 0.1em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    margin-bottom: 2.5rem;
    color: rgba(255, 255, 255, 0.92);
  }

  /* CTAボタン群（3つ等幅） */
  .hero-cta-group {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.875rem;
    width: 100%;
    max-width: 540px;
    margin: 0.75rem auto 0;
  }

  .hero-cta {
    --cta-pad-y: 1.05rem;
    --cta-pad-x: 1rem;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: var(--cta-pad-y) var(--cta-pad-x);
    aspect-ratio: 1.7 / 1;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.28);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    backdrop-filter: blur(1.5px);
    -webkit-backdrop-filter: blur(1.5px);
    transition: border-color 0.4s ease, transform 0.3s ease, box-shadow 0.4s ease;
  }

  /* 左上の細い装飾コーナー */
  .hero-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 18px;
    height: 18px;
    border-top: 1px solid var(--color-sky, #6EC6F0);
    border-left: 1px solid var(--color-sky, #6EC6F0);
    opacity: 0.65;
    transition: width 0.35s ease, height 0.35s ease, opacity 0.3s ease;
  }

  /* 右下のスライドする塗り（hover時に sky blue が満ちる） */
  .hero-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-sky, #6EC6F0);
    transform: translateX(-101%);
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1);
    z-index: -1;
  }

  .hero-cta-en {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.32em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
    transition: letter-spacing 0.3s ease, color 0.3s ease;
  }

  .hero-cta-ja {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    line-height: 1;
    transition: color 0.3s ease;
  }

  .hero-cta-arrow {
    position: absolute;
    bottom: 0.65rem;
    right: 0.85rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.45);
    transition: transform 0.35s ease, color 0.3s ease, opacity 0.3s ease;
  }

  /* hover: sky blue が満ち、テキストは deep blue で高コントラスト */
  .hero-cta:hover {
    border-color: var(--color-sky, #6EC6F0);
    transform: translateY(-3px);
    box-shadow: 0 12px 28px -8px rgba(110, 198, 240, 0.45);
  }

  .hero-cta:hover::before {
    width: 30px;
    height: 30px;
    opacity: 1;
    border-color: var(--color-deep, #1B3F8B);
  }

  .hero-cta:hover::after {
    transform: translateX(0);
  }

  .hero-cta:hover .hero-cta-en {
    color: var(--color-deep, #1B3F8B);
    letter-spacing: 0.4em;
  }

  .hero-cta:hover .hero-cta-ja {
    color: var(--color-deep, #1B3F8B);
  }

  .hero-cta:hover .hero-cta-arrow {
    color: var(--color-deep, #1B3F8B);
    transform: translateX(4px);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-sky, #6EC6F0);
    outline-offset: 3px;
  }

  @media (max-width: 480px) {
    .hero-cta-group {
      gap: 0.55rem;
      max-width: 100%;
    }
    .hero-cta {
      --cta-pad-x: 0.5rem;
      aspect-ratio: 1.3 / 1;
    }
    .hero-cta-ja {
      font-size: 0.875rem;
      letter-spacing: 0.08em;
    }
    .hero-cta-en {
      font-size: 0.625rem;
      letter-spacing: 0.25em;
    }
    .hero-cta-arrow {
      bottom: 0.4rem;
      right: 0.5rem;
      font-size: 0.8rem;
    }
  }

  /* 最新記事セクション */
  .latest-section {
    padding: 5rem 0;
  }

  .section-inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-heading {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .section-heading-en {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--color-sky, #6EC6F0);
    text-transform: uppercase;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .no-articles {
    text-align: center;
    color: rgba(26, 31, 46, 0.5);
    padding: 3rem 0;
  }

  .section-more {
    margin-top: 3rem;
    text-align: center;
  }

  .more-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-deep, #1B3F8B);
    text-decoration: none;
    border-bottom: 2px solid var(--color-gold, #D4A84B);
    padding-bottom: 0.25rem;
    transition: color 0.2s ease;
    letter-spacing: 0.05em;
  }

  .more-link:hover {
    color: var(--color-sky, #6EC6F0);
  }

  @media (max-width: 900px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  /* 夢源風人について */
  .about-section {
    padding: 5rem 0;
    background: #ffffff;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .about-card--main {
    grid-column: 1 / -1;
  }

  .about-card {
    /* 大きすぎる角丸は「アプリ風」に寄り帯と浮くため、抑えめに */
    --about-card-radius: 12px;
    position: relative;
    background:
      linear-gradient(160deg, rgba(240, 246, 255, 0.92), rgba(255, 255, 255, 0.98));
    border-radius: var(--about-card-radius);
    padding: 1.85rem 2rem;
    border: 1px solid rgba(110, 198, 240, 0.26);
    box-shadow:
      0 10px 28px rgba(27, 63, 139, 0.08),
      0 2px 10px rgba(26, 31, 46, 0.05);
    overflow: hidden;
  }

  .about-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 12% 0%, rgba(110, 198, 240, 0.16), transparent 62%),
      radial-gradient(95% 70% at 92% 100%, rgba(212, 168, 75, 0.12), transparent 64%);
    pointer-events: none;
  }

  /* 左アクセント：カード左辺と同じRのみ。細めで角丸カードと馴染ませる */
  .about-card::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: var(--about-card-radius) 0 0 var(--about-card-radius);
    background: linear-gradient(
      180deg,
      rgba(110, 198, 240, 0.95),
      rgba(27, 63, 139, 0.82)
    );
  }

