---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="メンバー | 夢源風人"
  description="夢源風人メンバー専用ページです。"
>
  <div class="members-page">
    <div class="page-inner">
      <div class="protected-notice">
        <div class="notice-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h1 class="notice-title">メンバー専用ページ</h1>
        <p class="notice-body">
          このページはメンバー専用です。<br />
          Cloudflare Zero Trust で保護されています。
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .members-page {
    padding-top: 64px; /* header height */
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .page-inner {
    max-width: 600px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    width: 100%;
  }

  .protected-notice {
    background: #ffffff;
    border-radius: 12px;
    padding: 3rem 2.5rem;
    text-align: center;
    box-shadow: 0 4px 24px rgba(27, 63, 139, 0.1);
    border-top: 4px solid var(--color-gold, #D4A84B);
  }

  .notice-icon {
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .notice-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-deep, #1B3F8B);
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .notice-body {
    font-size: 1rem;
    line-height: 2;
    color: rgba(26, 31, 46, 0.65);
    letter-spacing: 0.03em;
  }
</style>
