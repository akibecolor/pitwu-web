<style>
  .placeholder {
    text-align: center;
    padding: 4rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .placeholder p {
    color: rgba(26, 31, 46, 0.5);
    font-size: 0.9375rem;
  }

  .placeholder a {
    color: var(--color-deep, #1B3F8B);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .placeholder a:hover {
    text-decoration: underline;
  }
</style>
