---
import type { Article } from '../types/index.js';

interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

// 表示日: wpDate があれば優先（WordPress からの投稿日）、なければ publishedAt（新規記事）
const sourceDate = article.wpDate || article.publishedAt;
const date = new Date(sourceDate);
const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, '0');
const slug = decodeURIComponent(article.slug);
const href = `/${year}/${month}/${slug}`;

const displayDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={['article-card', { 'article-card--featured': featured }]}>
  <a href={href} class="card-link" aria-label={article.title}>
    <div class="card-image-wrap">
      {article.eyecatch ? (
        <img
          src={article.eyecatch.url}
          alt={article.title}
          width={article.eyecatch.width}
          height={article.eyecatch.height}
          loading="lazy"
          decoding="async"
          class="card-image"
        />
      ) : (
        <div class="card-image card-image--placeholder" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      )}
      {article.category && (
        <span class="card-category">{article.category.name}</span>
      )}
    </div>

    <div class="card-body">
      <h2 class="card-title">{article.title}</h2>
      <time class="card-date" datetime={sourceDate}>{displayDate}</time>
      {article.tags && article.tags.length > 0 && (
        <ul class="card-tags" aria-label="タグ">
          {article.tags.map((tag) => (
            <li class="card-tag">{tag.name}</li>
          ))}
        </ul>
      )}
    </div>
  </a>
</article>

<style>
  .article-card {
    background: #ffffff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(27, 63, 139, 0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(27, 63, 139, 0.15);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .article-card--featured .card-image-wrap {
    aspect-ratio: 16 / 8;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .article-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-base, #F0F6FF) 0%, #d8eaf8 100%);
    color: var(--color-sky, #6EC6F0);
  }

  .card-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background-color: var(--color-deep, #1B3F8B);
    color: #ffffff;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.625rem;
    border-radius: 2px;
  }

  .card-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-title {
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-ink, #1A1F2E);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card--featured .card-title {
    font-size: 1.25rem;
    -webkit-line-clamp: 4;
  }

  .card-date {
    font-size: 0.75rem;
    color: rgba(26, 31, 46, 0.5);
    letter-spacing: 0.03em;
    margin-top: auto;
  }

  .card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .card-tag {
    font-size: 0.6875rem;
    color: var(--color-sky, #6EC6F0);
    border: 1px solid var(--color-sky, #6EC6F0);
    border-radius: 999px;
    padding: 0.125rem 0.5rem;
    letter-spacing: 0.04em;
  }
</style>
