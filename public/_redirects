# WordPress 管理画面・サインイン → トップへ
/wp-admin/* / 301
/wp-login.php / 301
/wp-cron.php / 301
/xmlrpc.php / 301

# WordPress 既定の静的ファイル → 404
/wp-includes/* / 404
/wp-json/* / 404
